@using ChokaQ.TheDeck.Enums
@using ChokaQ.Abstractions.DTOs
@using ChokaQ.Abstractions.Enums
@namespace ChokaQ.TheDeck.UI.Components.OpsPanel.HistoryFilter

<div class="filter">
    <div class="filter__header">
        <span class="filter__context-badge @(Context == JobSource.DLQ ? "filter__context-badge--dlq" : "filter__context-badge--archive")">
            SOURCE: @Context.ToString().ToUpper()
        </span>
    </div>

    <div class="filter__group">
        <label class="filter__label">Date Range</label>
        <div class="filter__row">
            <input type="date" class="filter__input" @bind="_dateFrom" />
            <span class="filter__sep">-</span>
            <input type="date" class="filter__input" @bind="_dateTo" />
        </div>
    </div>

    <div class="filter__group">
        <label class="filter__label">Search Query</label>
        <input type="text"
               class="filter__input filter__input--search"
               placeholder="ID, Type, Tags, Error..."
               @bind="_searchTerm"
               @bind:event="oninput"
               @onkeyup="@(e => e.Key == "Enter" ? HandleSearchClick() : Task.CompletedTask)" />
    </div>

    <div class="filter__group">
        <div class="filter__row">
            <div class="filter__col">
                <label class="filter__label">Queue</label>
                <input type="text" class="filter__input" placeholder="All" @bind="_queue" />
            </div>
            <div class="filter__col">
                <label class="filter__label">Limit</label>
                <select class="filter__select" value="@_selectedPageSize" @onchange="HandlePageSizeChange">
                    <option value="100">100</option>
                    <option value="500">500</option>
                    <option value="1000">1000</option>
                </select>
            </div>
        </div>
    </div>

    @if (Context == JobSource.DLQ)
    {
        <div class="filter__group">
            <div class="filter__row">
                <div class="filter__col">
                    <label class="filter__label">Failure Reason</label>
                    <select class="filter__select" @bind="_failureReason">
                        <option value="">All</option>
                        @foreach (var reason in Enum.GetValues<FailureReason>())
                        {
                            <option value="@reason.ToString()">@reason</option>
                        }
                    </select>
                </div>
                <div class="filter__col">
                    <label class="filter__label">Job Type</label>
                    <input type="text" class="filter__input" placeholder="All" @bind="_jobType" />
                </div>
            </div>
        </div>
    }

    <div class="filter__group">
        <label class="filter__label">Sort By</label>
        <div class="filter__row">
            <select class="filter__select" value="@_sortBy" @onchange="HandleSortChange">
                <option value="Date">Date</option>
                <option value="Duration">Duration</option>
                <option value="Type">Type</option>
                <option value="Queue">Queue</option>
                <option value="Attempts">Attempts</option>
            </select>
            <button class="deck-btn filter__sort-btn" @onclick="ToggleSortDirection" title="Toggle ASC/DESC">
                @(_sortDesc ? "DESC" : "ASC")
            </button>
        </div>
    </div>

    <div class="filter__actions">
        <button class="deck-btn deck-btn-primary filter__load-btn" @onclick="HandleSearchClick">
            LOAD DATA
        </button>
    </div>

    @if (Context == JobSource.DLQ)
    {
        <div class="filter__bulk">
            <div class="filter__bulk-header">
                <span class="filter__label">Bulk DLQ</span>
                <input type="number"
                       min="1"
                       max="@DlqBulkOperationFilterDto.AbsoluteMaxJobs"
                       class="filter__input filter__bulk-limit"
                       @bind="_bulkMaxJobs" />
            </div>
            <div class="filter__row">
                <button class="deck-btn filter__bulk-btn" disabled="@_isBulkBusy" @onclick="PreviewBulkRequeue">
                    PREVIEW REQUEUE
                </button>
                <button class="deck-btn deck-btn-danger filter__bulk-btn" disabled="@_isBulkBusy" @onclick="PreviewBulkPurge">
                    PREVIEW PURGE
                </button>
            </div>

            @if (_bulkPreview != null)
            {
                <div class="filter__bulk-preview">
                    <div class="filter__bulk-line">
                        <span class="deck-badge deck-badge--info">@BulkConfirmationToken</span>
                        <span>@_bulkPreview.WillAffectCount.ToString("N0") / @_bulkPreview.MatchedCount.ToString("N0") matched</span>
                    </div>
                    @if (_bulkPreview.IsTruncated)
                    {
                        <div class="filter__bulk-note">Capped at @_bulkPreview.MaxJobs.ToString("N0") jobs</div>
                    }
                    @if (_bulkPreview.SampleJobIds.Count > 0)
                    {
                        <div class="filter__bulk-sample">@string.Join(", ", _bulkPreview.SampleJobIds)</div>
                    }
                    <div class="filter__row">
                        <input type="text"
                               class="filter__input"
                               placeholder="@BulkConfirmationToken"
                               @bind="_bulkConfirmation"
                               @bind:event="oninput" />
                        <button class="deck-btn deck-btn-danger filter__bulk-confirm"
                                disabled="@(!CanExecuteBulk)"
                                @onclick="ExecuteBulkOperation">
                            CONFIRM
                        </button>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_bulkResultMessage))
            {
                <div class="filter__bulk-result">@_bulkResultMessage</div>
            }
        </div>
    }

    <hr class="deck-hr" />

    <div class="filter__status">
        @if (TotalItems > 0)
        {
            @if (PageSize == 10) // DETECT PREVIEW MODE
            {
                <div class="filter__stats filter__stats--preview">
                    <span class="deck-badge deck-badge--info">PREVIEW</span>
                    <br />
                    Showing last <strong>10</strong> of <span class="filter__count">@TotalItems.ToString("N0")</span>
                    <br />
                    <small>Click "LOAD DATA" for full list</small>
                </div>
            }
            else // NORMAL PAGINATION MODE
            {
                <div class="filter__stats">
                    Found: <span class="filter__count">@TotalItems.ToString("N0")</span> records
                    <br />
                    Page @CurrentPage of @TotalPages
                </div>

                @if (TotalPages > 1)
                {
                    <div class="filter__paging">
                        <button class="deck-btn filter__page-btn" disabled="@(!CanGoPrev)" @onclick="HandlePrev">PREV</button>
                        <span class="filter__page-current">@CurrentPage</span>
                        <button class="deck-btn filter__page-btn" disabled="@(!CanGoNext)" @onclick="HandleNext">NEXT</button>
                    </div>
                }
            }
        }
        else
        {
            <div class="filter__empty">No data loaded (or 0 found)</div>
        }
    </div>
</div>
