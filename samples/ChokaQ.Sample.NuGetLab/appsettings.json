{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "ChokaQ.Sample.NuGetLab": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ChokaQDb": ""
  },
  "ChokaQ": {
    "Execution": {
      "DefaultTimeout": "00:00:12",
      "HeartbeatIntervalMin": "00:00:01",
      "HeartbeatIntervalMax": "00:00:02",
      "HeartbeatFailureThreshold": 3
    },
    "Retry": {
      "MaxAttempts": 3,
      "BaseDelay": "00:00:02",
      "MaxDelay": "00:00:10",
      "BackoffMultiplier": 2.0,
      "JitterMaxDelay": "00:00:01",
      "CircuitBreakerDelay": "00:00:05",
      "MaxJobAge": "00:05:00"
    },
    "Recovery": {
      "FetchedJobTimeout": "00:00:20",
      "ProcessingZombieTimeout": "00:00:20",
      "ScanInterval": "00:00:10"
    },
    "Worker": {
      "ShutdownGracePeriod": "00:00:15"
    },
    "Health": {
      "WorkerHeartbeatTimeout": "00:00:20",
      "QueueLagDegradedThreshold": "00:00:05",
      "QueueLagUnhealthyThreshold": "00:00:15"
    },
    "Metrics": {
      "MaxQueueTagValues": 25,
      "MaxJobTypeTagValues": 50,
      "MaxErrorTagValues": 25,
      "MaxFailureReasonTagValues": 25,
      "MaxTagValueLength": 96,
      "UnknownTagValue": "unknown",
      "OverflowTagValue": "other"
    },
    "Queues": {
      "critical": {
        "ExecutionTimeout": "00:00:08"
      },
      "reports": {
        "ExecutionTimeout": "00:00:25"
      },
      "unstable": {
        "ExecutionTimeout": "00:00:06"
      }
    },
    "Idempotency": {
      "InProgressTtl": "00:01:00",
      "DefaultResultTtl": "00:10:00"
    },
    "SqlServer": {
      "ConnectionString": "",
      "SchemaName": "chokaq_lab",
      "AutoCreateSqlTable": true,
      "PollingInterval": "00:00:00.500",
      "NoQueuesSleepInterval": "00:00:02",
      "CommandTimeoutSeconds": 30,
      "CleanupBatchSize": 500,
      "MaxTransientRetries": 3,
      "TransientRetryBaseDelayMs": 150,
      "WorkerShutdownGracePeriod": "00:00:15",
      "PrefetchedJobReleaseTimeout": "00:00:03"
    }
  }
}
